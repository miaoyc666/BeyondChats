{
  "name": "beyondchats",
  "version": "0.1.0",
  "description": "A multi-AI chat desktop application supporting ChatGPT, Gemini, Douban, Qwen, and Yuanbao",
  "main": "dist/electron/main.js",
  "homepage": "./",
  "author": {
    "name": "miaoyc",
    "email": "miaoyc666@outlook.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"npm run vite\" \"npm run electron-dev\"",
    "vite": "vite",
    "electron-dev": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:renderer && npm run build:electron && npm run build:app",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:app": "electron-builder",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "build:linux": "npm run build -- --linux",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.vue",
    "format": "prettier --write ."
  },
  "dependencies": {
    "axios": "^1.6.2",
    "element-plus": "^2.13.2",
    "pinia": "^2.1.7",
    "vue": "^3.3.13",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/test-utils": "^2.4.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-is-dev": "^3.0.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "wait-on": "^7.1.0"
  },
  "build": {
    "appId": "com.beyondchats.app",
    "productName": "BeyondChats",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "dist/electron/**/*",
      "dist/renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
